{
  "name": "dop-fe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3001",
    "build": "tsc --noEmit && next build --turbopack",
    "build:static": "tsc --noEmit && next build --turbopack",
    "type-check": "tsc --noEmit",
    "type-check:files": "npx @jbabin91/tsc-files --skip-lib-check",
    "type-check:changed": "git diff --name-only --diff-filter=ACM | grep -E '\\.(ts|tsx)$' | xargs npx @jbabin91/tsc-files --skip-lib-check",
    "type-check:staged": "git diff --cached --name-only --diff-filter=ACM | grep -E '\\.(ts|tsx)$' | xargs npx @jbabin91/tsc-files --skip-lib-check",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "gen:api": "pnpm gen:api:dop && pnpm gen:api:consent",
    "gen:api:dop": "openapi-typescript src/lib/api/specs/dop.yaml -o src/lib/api/v1/dop.d.ts",
    "gen:api:consent": "openapi-typescript src/lib/api/specs/consent.yaml -o src/lib/api/v1/consent.d.ts",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:codegen": "playwright codegen",
    "test:all": "pnpm test:run",
    "validate-css-migration": "node scripts/css-migration-validator.js",
    "translations:add": "node scripts/translation-cli.js add",
    "translations:validate": "node scripts/translation-cli.js validate",
    "translations:stats": "node scripts/translation-cli.js stats",
    "translations:missing": "node scripts/translation-cli.js missing",
    "translations:duplicates": "node scripts/translation-cli.js duplicates",
    "translations:extract": "node scripts/translation-cli.js extract",
    "translations:extract:output": "node scripts/translation-cli.js extract --output=docs/i18n/used-keys.json"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "npx @biomejs/biome format --write"
  },
  "overrides": {
    "webpack": "5.101.2"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-table": "^8.21.3",
    "@types/react-window": "^1.8.8",
    "@vercel/analytics": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "culori": "^4.0.2",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.25",
    "immer": "^11.0.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.555.0",
    "motion": "^12.23.24",
    "next": "15.5.4",
    "next-intl": "^4.3.9",
    "next-themes": "^0.4.6",
    "openapi-fetch": "^0.15.0",
    "react": "19.1.0",
    "react-day-picker": "^9.11.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.63.0",
    "react-paginate": "^8.3.0",
    "react-resizable-panels": "^3.0.6",
    "react-responsive": "^10.0.1",
    "react-window": "^2.2.3",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^13.0.0",
    "vaul": "^1.1.2",
    "zod": "^4.1.11",
    "zustand": "^5.0.8",
    "zustand-cookie-storage": "^1.1.1"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@jbabin91/tsc-files": "^0.8.2",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-a11y": "~8.6.14",
    "@storybook/addon-docs": "~8.6.14",
    "@storybook/addon-essentials": "~8.6.14",
    "@storybook/addon-interactions": "~8.6.14",
    "@storybook/addon-onboarding": "~8.6.14",
    "@storybook/nextjs": "~8.6.14",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/culori": "^4.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-paginate": "^7.1.4",
    "@types/react-responsive": "^9.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dompurify": "^3.3.1",
    "embla-carousel-autoplay": "^8.6.0",
    "fast-check": "^4.5.3",
    "glob": "^13.0.0",
    "husky": "^9.1.7",
    "inquirer": "^13.2.2",
    "jsdom": "^27.2.0",
    "lint-staged": "^16.2.3",
    "msw": "^2.12.4",
    "openapi-typescript": "^7.9.1",
    "ora": "^9.1.0",
    "playwright": "^1.55.1",
    "playwright-bdd": "^8.4.2",
    "sanitize-filename": "^1.6.3",
    "sanitize-html": "^2.17.0",
    "storybook": "~8.6.14",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "webpack": "5.101.2"
  }
}
