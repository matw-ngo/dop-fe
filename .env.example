# eKYC Configuration

# eKYC Backend Proxy URL (leave empty to call VNPT directly)
NEXT_PUBLIC_EKYC_BACKEND_URL=""
# or for server-side only:
# EKYC_BACKEND_URL="https://your-backend.com/api/ekyc-proxy"

# eKYC Token Configuration
# These should match your VNPT account configuration
NEXT_PUBLIC_EKYC_TOKEN_KEY="+=="
NEXT_PUBLIC_EKYC_TOKEN_ID="b85b"

# eKYC Authorization Token
# This is sensitive and should be obtained from your backend
# DO NOT hardcode this in production frontend code
NEXT_PUBLIC_EKYC_AUTH_TOKEN="your-vnpt-authorization-token"
# or better, use server-side only:
# EKYC_AUTH_TOKEN="your-vnpt-authorization-token"

# Development vs Production
NODE_ENV="development"

# Optional: Override for different environments
# EKYC_ENVIRONMENT="development" # development | staging | production

# API Environment (development | staging | production)
NEXT_PUBLIC_API_ENVIRONMENT="staging"

# API Configuration
# Toggle between mock API and real API for admin endpoints
# Set to 'true' to use mock data, 'false' or remove to use real API
NEXT_PUBLIC_USE_MOCK_API="false"

# API Base URL for real API calls (can override default for each environment)
# Development: http://localhost:3001/api/v1
# Staging: https://dop-stg.datanest.vn/v1
# Production: https://api.dop-fe.com/v1
NEXT_PUBLIC_API_URL="https://dop-stg.datanest.vn/v1"

# API Keys and Secrets (for production, these should be stored securely)
# NEXT_PUBLIC_API_KEY=""
# API_SECRET="your-api-secret"